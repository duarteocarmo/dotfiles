{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp"
      ],
      "enabled": true
    },
    "fetch": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-server-fetch"
      ],
      "enabled": true
    },
    "vibium": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "vibium"
      ],
      "enabled": false
    }
  },
  "plugin": [
    "opencode-reminders"
  ],
  "provider": {
    "llama.cpp": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "llama-server (local)",
      "options": {
        "baseURL": "http://127.0.0.1:8080/v1"
      },
      "models": {
        "unsloth/Qwen3.5-35B-A3B-GGUF:UD-Q4_K_M": {
          "name": "Qwen3.5-35B-A3B-GGUF:UD-Q4_K_M",
          "limit": {
            "context": 128000,
            "output": 65536
          }
        }
      }
    }
  }
}
